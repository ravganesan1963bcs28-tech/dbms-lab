2]B.write a function to display average salary of each work

SQL> CREATE OR REPLACE FUNCTION avg_salary_by_work
  2  RETURN SYS_REFCURSOR
  3  IS
  4     c_cursor SYS_REFCURSOR;
  5  BEGIN
  6     OPEN c_cursor FOR
  7        SELECT work_name, AVG(salary) AS avg_salary
  8        FROM teaching_staff
  9        GROUP BY work_name;
 10
 11     RETURN c_cursor;
 12  END avg_salary_by_work;
 13  /

Function created.
SQL> DECLARE
  2     v_cursor SYS_REFCURSOR;
  3     v_work   VARCHAR2(50);
  4     v_avg    NUMBER;
  5  BEGIN
  6     v_cursor := avg_salary_by_work;
  7
  8     DBMS_OUTPUT.PUT_LINE('WORK_NAME    AVG_SALARY');
  9
 10     LOOP
 11        FETCH v_cursor INTO v_work, v_avg;
 12        EXIT WHEN v_cursor%NOTFOUND;
 13
 14        DBMS_OUTPUT.PUT_LINE(v_work || '        ' || ROUND(v_avg,2));
 15     END LOOP;
 16
 17     CLOSE v_cursor;
