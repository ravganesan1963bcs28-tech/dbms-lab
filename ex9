3]B.write a function to display staff and their salary who are working with a salary lower than average salary of their work

SQL> CREATE OR REPLACE FUNCTION staff_below_avg(p_work VARCHAR2)
  2  RETURN SYS_REFCURSOR
  3  IS
  4     c_cursor SYS_REFCURSOR;
  5  BEGIN
  6     OPEN c_cursor FOR
  7        SELECT *
  8        FROM teaching_staff
  9        WHERE salary < (
 10           SELECT AVG(salary)
 11           FROM teaching_staff
 12           WHERE work_name = p_work
 13        );
 14
 15     RETURN c_cursor;
 16  END staff_below_avg;
 17  /

