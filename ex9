2]A. write a pl/sql function to find highest salary of each work

SQL> CREATE OR REPLACE PROCEDURE highest_salary_staff
  2  IS
  3     CURSOR dept_cur IS
  4        SELECT DISTINCT work_name FROM teaching_staff;

  5     CURSOR staff_cur(p_work teaching_staff.work_name%TYPE) IS
  6        SELECT staff_id, salary, work_name
  7        FROM teaching_staff
  8        WHERE work_name = p_work
  9        AND salary = (SELECT MAX(salary)
 10                      FROM teaching_staff
 11                      WHERE work_name = p_work);

 12     v_staff_id NUMBER;
 13     v_salary   NUMBER;
 14     v_work     VARCHAR2(50);
 15  BEGIN
 16     FOR d IN dept_cur LOOP   -- OUTER LOOP
 17
 18        FOR s IN staff_cur(d.work_name) LOOP   -- INNER LOOP
 19
 20           DBMS_OUTPUT.PUT_LINE(
 21           'WORK: ' || d.work_name ||
 22           ' STAFF_ID: ' || s.staff_id ||
 23           ' SALARY: ' || s.salary);
 24
 25        END LOOP;
 26
 27     END LOOP;
