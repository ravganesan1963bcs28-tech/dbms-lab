3]A.find the work with maximum no of staff working

SQL> CREATE OR REPLACE PROCEDURE max_staff_department(p_work OUT VARCHAR2)
  2  IS
  3  BEGIN
  4     SELECT work_name
  5     INTO p_work
  6     FROM (
  7        SELECT work_name, COUNT(*) cnt
  8        FROM teaching_staff
  9        GROUP BY work_name
 10        ORDER BY cnt DESC
 11     )
 12     WHERE ROWNUM = 1;
 13  END max_staff_department;
 14  /

